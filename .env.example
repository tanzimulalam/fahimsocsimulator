# Copy to `.env` locally. Do not commit `.env`.
#
# Dev: prefer OPENAI_API_KEY (not bundled). Vite dev server proxies /__openai → OpenAI.
# OPENAI_API_KEY=sk-...
# Or use VITE_OPENAI_API_KEY for the proxy only (still avoid committing real keys).
#
# Production (GitHub Pages): deploy workers/tutor-proxy.mjs (Cloudflare Worker), then set
# GitHub repo Variable VITE_TUTOR_API_URL=https://your-worker.workers.dev
VITE_TUTOR_API_URL=
# Shared classroom memory/database API (same Worker can serve /api/*)
VITE_API_BASE_URL=
OPENAI_API_KEY=
